# atomic-atlas environment file — example
#
# Copy this to .env at the repo root and fill in the values you need:
#
#     cp .env.example .env
#
# .env is .gitignored; .env.example is the only .env-shaped file checked
# into the repo. Values in .env OVERRIDE the shell environment (project
# preference). Set ATOMIC_ATLAS_SKIP_DOTENV=1 if you want shell env to win.
#
# Every variable below is OPTIONAL. atomic-atlas runs with sensible
# defaults when nothing is set; the .env file is for opting in to
# attacker-LLM-driven mutation, custom adapter auth, or non-default models.

# ─────────────────────────────────────────────────────────────────────────
# Attacker LLM (drives RedTeamingAttack payload mutation)
# ─────────────────────────────────────────────────────────────────────────

# Required for RedTeamingAttack-tagged atomics to actually mutate payloads
# across runs. Without it, atomic-atlas auto-falls-back to PromptSendingAttack
# and logs a warning.
OPENAI_API_KEY=

# Override the OpenAI endpoint to point at a LiteLLM / vLLM / Ollama-OpenAI
# proxy if you want the attacker to use a non-OpenAI provider.
# OPENAI_API_BASE=https://api.openai.com/v1

# Model name for the attacker LLM. Default is gpt-4o.
# ATOMIC_ATLAS_ATTACKER_MODEL=gpt-4o
# ATOMIC_ATLAS_ATTACKER_MODEL=gpt-4o-mini

# Force PromptSendingAttack for every atomic regardless of frontmatter tag.
# Useful for offline / no-API-key environments and CI runs where you don't
# want the attacker LLM to interfere with verifying the target side.
# ATOMIC_ATLAS_NO_ATTACKER_LLM=1

# Reserved. PyRIT 0.13 does not ship a first-class Anthropic chat target;
# use OPENAI_API_BASE pointing at a LiteLLM proxy instead.
# ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# atomic-atlas runtime
# ─────────────────────────────────────────────────────────────────────────

# Engagement directory — accumulates atomic + runbook results across runs
# (timestamped JSONL). Default: ./atomic-atlas-engagement/ in the cwd.
# Set this for multi-target / multi-day engagements where you want one
# folder per customer. The dir auto-initializes on first write.
# ATOMIC_ATLAS_ENGAGEMENT_DIR=/path/to/customer-x.engagement/

# PyRIT memory backing. Default ":memory:" gives a fast ephemeral SQLite
# store; set a path for persistent memory across runs.
# ATOMIC_ATLAS_PYRIT_DB=:memory:
# ATOMIC_ATLAS_PYRIT_DB=/tmp/atomic-atlas-pyrit.db

# Alternate atomics catalog directory. Used by the MCP server when running
# from outside the repo. Defaults to <repo>/atomics/.
# ATOMIC_ATLAS_ATOMICS_DIR=/path/to/your/atomics/

# Disable the .env auto-loader (let shell env win).
# ATOMIC_ATLAS_SKIP_DOTENV=1

# ─────────────────────────────────────────────────────────────────────────
# Target profile auth (referenced via ${VAR_NAME} in targets/*.yaml)
# ─────────────────────────────────────────────────────────────────────────

# DVAA training target — auth is not actually enforced; placeholder kept
# for forward-compat with hardened DVAA forks.
# DVAA_API_KEY=unused

# MCP server bearer token, when the target's MCP registry requires auth.
# MCP_TOKEN=

# Azure AI Search admin key (RAGCorpusTarget azure_search backend).
# AZURE_SEARCH_KEY=

# Azure OpenAI key (DirectChatTarget against Azure-hosted endpoints).
# AZURE_OPENAI_KEY=

# Generic target bearer (DirectChatTarget, custom adapters).
# TARGET_API_KEY=

# Bearer for an OpenAI-compatible file-upload endpoint (DocumentUploadTarget).
# UPLOAD_TOKEN=

# ─────────────────────────────────────────────────────────────────────────
# Lobster (the bundled vulnerable agent — v0.2 scope)
# ─────────────────────────────────────────────────────────────────────────

# 1 to bind 0.0.0.0 (default is 127.0.0.1 — Lobster refuses public bind
# without this override).
# LOBSTER_BIND_ALL=

# Set to enable HMAC-signed mode on Lobster's webhook endpoint.
# LOBSTER_WEBHOOK_HMAC=
